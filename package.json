{
  "name": "xenonjs",
  "version": "1.0.5",
  "description": "Lightweight event-driven DOM utility library with modular architecture",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.iife.js",
  "unpkg": "./dist/index.iife.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js",
      "browser": "./dist/index.iife.js",
      "default": "./src/index.js"
    },
    "./bus": {
      "import": "./dist/bus.js",
      "require": "./dist/bus.umd.js",
      "default": "./src/bus.js"
    },
    "./all": {
      "import": "./dist/all.js",
      "require": "./dist/all.umd.js",
      "default": "./src/all.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.config.iife.js && vite build --config vite.config.all-iife.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dom",
    "dom-utils",
    "dom-manipulation",
    "events",
    "event-bus",
    "javascript",
    "frontend",
    "utility",
    "library",
    "lightweight",
    "selector",
    "wrapper",
    "jquery-like",
    "context-menu",
    "ui",
    "vanilla-js"
  ],
  "author": "Stelios Ignatiadis",
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "homepage": "https://github.com/actusworks/xenonjs#readme",
  "repository": "github:actusworks/xenonjs",
  "bugs": {
    "url": "https://github.com/actusworks/xenonjs/issues"
  },
  "devDependencies": {
    "vite": "^8.0.3"
  }
}
